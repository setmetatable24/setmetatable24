function MathUtils.vector3Reciprocal(value: Vector3, fallback: number?): Vector3
	local f = fallback or 0
	return Vector3.new(
		MathUtils.safeDivide(1, value.X, f),
		MathUtils.safeDivide(1, value.Y, f),
		MathUtils.safeDivide(1, value.Z, f)
	)
